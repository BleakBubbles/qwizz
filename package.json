{
	"name": "qwizz",
	"version": "0.1.0",
	"description": "Check your understanding while you vibe code",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/BleakBubbles/qwizz.git"
	},
	"homepage": "https://github.com/BleakBubbles/qwizz#readme",
	"bugs": {
		"url": "https://github.com/BleakBubbles/qwizz/issues"
	},
	"keywords": [
		"git-hooks",
		"quiz",
		"learning",
		"cli",
		"commit"
	],
	"type": "module",
	"bin": {
		"qwizz": "./dist/cli.js"
	},
	"files": [
		"dist",
		"dist-web",
		"README.md"
	],
	"scripts": {
		"build": "npm run build:cli && npm run build:web",
		"build:cli": "tsc -p tsconfig.json",
		"build:web": "vite build --config web/vite.config.ts",
		"dev:cli": "tsx src/cli.ts",
		"dev:web": "vite --config web/vite.config.ts",
		"prepublishOnly": "npm run build"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.0",
		"hono": "^4.0.0",
		"open": "^10.0.0",
		"qwizz-shared": "^0.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.19.15",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.0"
	}
}
